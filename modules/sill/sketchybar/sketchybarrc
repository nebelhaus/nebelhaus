#!/bin/bash

# Catppuccin Mocha Color Palette
export BASE=0xff1e1e2e
export MANTLE=0xff181825
export CRUST=0xff11111b
export TEXT=0xffcdd6f4
export SUBTEXT0=0xffa6adc8
export SUBTEXT1=0xffbac2de
export SURFACE0=0xff313244
export SURFACE1=0xff45475a
export SURFACE2=0xff585b70
export OVERLAY0=0xff6c7086
export OVERLAY1=0xff7f849c
export ROSEWATER=0xfff5e0dc
export FLAMINGO=0xfff2cdcd
export PINK=0xfff5c2e7
export MAUVE=0xffcba6f7
export RED=0xfff38ba8
export MAROON=0xffeba0ac
export PEACH=0xfffab387
export YELLOW=0xfff9e2af
export GREEN=0xffa6e3a1
export TEAL=0xff94e2d5
export SKY=0xff89dceb
export SAPPHIRE=0xff74c7ec
export BLUE=0xff89b4fa
export LAVENDER=0xffb4befe

# General bar appearance
sketchybar --bar \
    height=40 \
    blur_radius=30 \
    position=top \
    padding_left=10 \
    padding_right=10 \
    margin=0 \
    corner_radius=0 \
    color=$BASE \
    shadow=off \
    sticky=on \
    notch_width=0

# Default item settings
sketchybar --default \
    updates=when_shown \
    icon.font="Hack Nerd Font:Bold:17.0" \
    icon.color=$TEXT \
    icon.padding_left=8 \
    icon.padding_right=4 \
    label.font="Hack Nerd Font:Bold:14.0" \
    label.color=$TEXT \
    label.padding_left=4 \
    label.padding_right=8 \
    background.color=$SURFACE0 \
    background.corner_radius=12 \
    background.height=28 \
    background.padding_left=4 \
    background.padding_right=4

##### LEFT SIDE #####

# Apple logo
sketchybar --add item apple.logo left \
    --set apple.logo \
        icon= \
        icon.font="SF Pro:Black:16.0" \
        icon.color=$BLUE \
        icon.padding_left=6 \
        icon.padding_right=6 \
        label.drawing=off \
        background.padding_left=4 \
        background.padding_right=4 \
        background.color=$MANTLE \
        popup.background.border_width=2 \
        popup.background.corner_radius=10 \
        popup.background.border_color=$SURFACE0 \
        popup.background.color=$MANTLE \
        click_script="/Users/julienmartel/.config/nix/dotfiles/sketchybar/plugins/launch_palette.sh"

sketchybar --add item apple.prefs popup.apple.logo \
    --set apple.prefs \
        icon= \
        label="Preferences" \
        icon.padding_left=10 \
        label.padding_right=10 \
        background.height=30 \
        background.padding_left=0 \
        background.padding_right=0 \
        background.color=0x00000000 \
        background.drawing=off \
        click_script="open -a 'System Settings'; sketchybar --set apple.logo popup.drawing=off"

sketchybar --add item apple.activity popup.apple.logo \
    --set apple.activity \
        icon= \
        label="Activity" \
        icon.padding_left=10 \
        label.padding_right=10 \
        background.height=30 \
        background.padding_left=0 \
        background.padding_right=0 \
        background.color=0x00000000 \
        background.drawing=off \
        click_script="open -a 'Activity Monitor'; sketchybar --set apple.logo popup.drawing=off"

sketchybar --add item apple.lock popup.apple.logo \
    --set apple.lock \
        icon= \
        label="Lock Screen" \
        icon.padding_left=10 \
        label.padding_right=10 \
        background.height=30 \
        background.padding_left=0 \
        background.padding_right=0 \
        background.color=0x00000000 \
        background.drawing=off \
        click_script="osascript -e 'tell application \"System Events\" to keystroke \"q\" using {control down, command down}'; sketchybar --set apple.logo popup.drawing=off"

sketchybar --add item apple.nix_config popup.apple.logo \
    --set apple.nix_config \
        icon= \
        label="Nix Config" \
        icon.padding_left=10 \
        label.padding_right=10 \
        background.height=30 \
        background.padding_left=0 \
        background.padding_right=0 \
        background.color=0x00000000 \
        background.drawing=off \
        click_script="/Users/julienmartel/.config/nix/dotfiles/sketchybar/plugins/nix_open.sh; sketchybar --set apple.logo popup.drawing=off"

sketchybar --add item apple.rebuild popup.apple.logo \
    --set apple.rebuild \
        icon=󰑓 \
        label="Rebuild System" \
        icon.padding_left=10 \
        label.padding_right=10 \
        background.height=30 \
        background.padding_left=0 \
        background.padding_right=0 \
        background.color=0x00000000 \
        background.drawing=off \
        click_script="/Users/julienmartel/.config/nix/dotfiles/sketchybar/plugins/launch_rebuild.sh"

sketchybar --add item apple.reload popup.apple.logo \
    --set apple.reload \
        icon= \
        label="Reload SketchyBar" \
        icon.padding_left=10 \
        label.padding_right=10 \
        background.height=30 \
        background.padding_left=0 \
        background.padding_right=0 \
        background.color=0x00000000 \
        background.drawing=off \
        click_script="sketchybar --reload; sketchybar --set apple.logo popup.drawing=off"

# Spaces - All AeroSpace workspaces
sketchybar --add event aerospace_workspace_change
WORKSPACES=("1" "2" "3" "4" "T" "N" "R" "S" "B" "F" "M" "H" "C" "D")

# App-workspaces show the app's logo (sketchybar-app-font ligature tokens);
# numbered workspaces keep their digit in the bar's Nerd Font. N is a shared
# notes workspace (Notes/Things/Obsidian) — defaulted to the Obsidian glyph.
for workspace in "${WORKSPACES[@]}"
do
    ICON="$workspace"
    IFONT="Hack Nerd Font:Bold:17.0"
    case "$workspace" in
        T) ICON=":ghostty:"     ; IFONT="sketchybar-app-font:Regular:16.0" ;;
        N) ICON=":obsidian:"    ; IFONT="sketchybar-app-font:Regular:16.0" ;;
        R) ICON=":things:"      ; IFONT="sketchybar-app-font:Regular:16.0" ;;
        S) ICON=":slack:"       ; IFONT="sketchybar-app-font:Regular:16.0" ;;
        B) ICON=":zen_browser:" ; IFONT="sketchybar-app-font:Regular:16.0" ;;
        F) ICON=":figma:"       ; IFONT="sketchybar-app-font:Regular:16.0" ;;
        M) ICON=":music:"       ; IFONT="sketchybar-app-font:Regular:16.0" ;;
        # Swather has no app-font glyph — use the Nerd Font hourglass (its icon).
        # fa-hourglass U+F254 as raw UTF-8 bytes (bash 3.2 printf has no \u).
        H) ICON=$(printf '\xEF\x89\x94') ;;
        C) ICON=":claude:"      ; IFONT="sketchybar-app-font:Regular:16.0" ;;
        D) ICON=":calendar:"    ; IFONT="sketchybar-app-font:Regular:16.0" ;;
    esac
    sketchybar --add item space.$workspace left \
        --set space.$workspace \
            icon="$ICON" \
            icon.font="$IFONT" \
            icon.drawing=on \
            icon.padding_left=10 \
            icon.padding_right=10 \
            icon.highlight_color=$YELLOW \
            background.color=$SURFACE0 \
            background.drawing=on \
            background.corner_radius=12 \
            background.height=28 \
            label.drawing=off \
            script="$HOME/.config/sketchybar/plugins/space.sh" \
            click_script="aerospace workspace $workspace" \
        --subscribe space.$workspace aerospace_workspace_change
done

# Aerospace workspace watcher - polls + listens for app changes to catch missed updates
sketchybar --add item aerospace_watcher left \
    --set aerospace_watcher \
        drawing=off \
        updates=on \
        update_freq=2 \
        script="$HOME/.config/sketchybar/plugins/aerospace_watcher.sh" \
    --subscribe aerospace_watcher front_app_switched space_change

# Empty-workspace reaction — when a ⌘Q leaves the focused workspace empty, pull
# back to the most recent populated workspace ("gravity") and keep the emptied
# one out of alt+tab. Non-drawing; see plugins/empty_workspace.sh for the
# quit-vs-switch detection and the back-and-forth re-pointing.
sketchybar --add item empty_workspace left \
    --set empty_workspace \
        drawing=off \
        updates=on \
        script="$HOME/.config/sketchybar/plugins/empty_workspace.sh" \
    --subscribe empty_workspace front_app_switched

# Front app name
sketchybar --add item front_app left \
    --set front_app \
        icon.drawing=off \
        background.color=$LAVENDER \
        label.color=$BASE \
        label.font="Hack Nerd Font:Bold:14.0" \
        label.padding_left=8 \
        label.padding_right=8 \
        script="$HOME/.config/sketchybar/plugins/front_app.sh" \
    --subscribe front_app front_app_switched

# Launch-mode picker — one bubble per leader hotkey, hidden until `launch` mode.
# plugins/launch_mode.sh shows + colors these (focused=mauve / open=green /
# closed=grey), hides the workspace + front_app pills, and turns the Apple logo
# into a → "go-to" glyph. The key list mirrors [mode.launch.binding] in
# aerospace.toml — keep them in sync.
LAUNCHER_KEYS=("t" "s" "b" "f" "m" "h" "c" "d" "n" "r" "p")
for key in "${LAUNCHER_KEYS[@]}"; do
    GLYPH=$(echo "$key" | tr '[:lower:]' '[:upper:]')
    sketchybar --add item launcher.$key left \
        --set launcher.$key \
            drawing=off \
            icon="$GLYPH" \
            icon.padding_left=10 \
            icon.padding_right=10 \
            label.drawing=off \
            background.color=$MANTLE \
            background.corner_radius=12 \
            background.height=28
done

# Leader-mode ("launch") feedback is handled by plugins/launch_mode.sh, which
# dims the bar, swaps the left side for the picker above, and glows the → lead.

##### RIGHT SIDE #####

# Clock (moved to far right)
sketchybar --add item clock right \
    --set clock \
        update_freq=10 \
        icon= \
        icon.color=$PINK \
        background.color=$MANTLE \
        background.padding_left=8 \
        background.padding_right=8 \
        script="$HOME/.config/sketchybar/plugins/clock.sh" \
        click_script="open -a 'Notion Calendar'"

# Weather
# Left-click: toggle popup | Right-click: open Weather app
sketchybar --add item weather right \
    --set weather \
        update_freq=600 \
        icon="󰖐" \
        icon.color=$SKY \
        background.color=$SURFACE0 \
        popup.background.border_width=2 \
        popup.background.corner_radius=10 \
        popup.background.border_color=$SURFACE0 \
        popup.background.color=$MANTLE \
        script="/Users/julienmartel/.config/nix/dotfiles/sketchybar/plugins/weather.sh" \
        click_script="if [ \"\$BUTTON\" = \"right\" ]; then open -a Weather; else sketchybar --set \$NAME popup.drawing=toggle; fi" \
    --subscribe weather system_woke mouse.clicked

# Weather popup styling helper
WEATHER_POPUP_ITEM=(
    icon.padding_left=10
    label.padding_right=10
    background.height=30
    background.padding_left=0
    background.padding_right=0
    background.color=0x00000000
    background.drawing=off
    icon.font="Hack Nerd Font:Bold:16.0"
    label.font="Hack Nerd Font:Regular:14.0"
)

# Weather popup - Location & Condition
sketchybar --add item weather.location popup.weather \
    --set weather.location "${WEATHER_POPUP_ITEM[@]}" \
        icon.color=$BLUE label.color=$TEXT

sketchybar --add item weather.condition popup.weather \
    --set weather.condition "${WEATHER_POPUP_ITEM[@]}" \
        icon.color=$SKY label.color=$SUBTEXT0

# Weather popup - Temperatures
sketchybar --add item weather.temp popup.weather \
    --set weather.temp "${WEATHER_POPUP_ITEM[@]}" \
        icon.color=$PEACH label.color=$TEXT

sketchybar --add item weather.highlow popup.weather \
    --set weather.highlow "${WEATHER_POPUP_ITEM[@]}" \
        icon.color=$RED label.color=$SUBTEXT0

# Weather popup - Sun times
sketchybar --add item weather.sun popup.weather \
    --set weather.sun "${WEATHER_POPUP_ITEM[@]}" \
        icon.color=$YELLOW label.color=$TEXT

# Weather popup - Wind & Humidity
sketchybar --add item weather.wind popup.weather \
    --set weather.wind "${WEATHER_POPUP_ITEM[@]}" \
        icon.color=$TEAL label.color=$TEXT

sketchybar --add item weather.humidity popup.weather \
    --set weather.humidity "${WEATHER_POPUP_ITEM[@]}" \
        icon.color=$SAPPHIRE label.color=$TEXT

# Weather popup - UV & Precipitation
sketchybar --add item weather.uv popup.weather \
    --set weather.uv "${WEATHER_POPUP_ITEM[@]}" \
        icon.color=$YELLOW label.color=$TEXT

sketchybar --add item weather.precip popup.weather \
    --set weather.precip "${WEATHER_POPUP_ITEM[@]}" \
        icon.color=$BLUE label.color=$TEXT

# Weather popup - Hourly forecast (next 4 hours)
for i in 0 1 2 3; do
    sketchybar --add item weather.hour.$i popup.weather \
        --set weather.hour.$i "${WEATHER_POPUP_ITEM[@]}" \
            icon.color=$LAVENDER label.color=$SUBTEXT0
done

# Weather popup - 3-day forecast
for i in 1 2 3; do
    sketchybar --add item weather.forecast.$i popup.weather \
        --set weather.forecast.$i "${WEATHER_POPUP_ITEM[@]}" \
            icon.color=$MAUVE label.color=$TEXT
done

# Media
sketchybar --add item media right \
    --set media \
        icon= \
        icon.color=$PINK \
        background.color=$SURFACE0 \
        background.padding_left=8 \
        background.padding_right=8 \
        label.max_chars=25 \
        scroll_texts=on \
        script="$HOME/.config/sketchybar/plugins/media.sh" \
    --subscribe media media_change

# Battery
sketchybar --add item battery right \
    --set battery \
        icon.color=$GREEN \
        background.color=$SURFACE0 \
        update_freq=30 \
        script="$HOME/.config/sketchybar/plugins/battery.sh" \
        click_script="open -a 'System Settings' 'x-apple.systempreferences:com.apple.preference.battery'" \
    --subscribe battery system_woke power_source_change

# WiFi
sketchybar --add item wifi right \
    --set wifi \
        icon=󰖩 \
        label.drawing=off \
