// Custom layout = tab-bar (top) + 1-line status-bar (bottom) + swap layouts.
// Three tiled swap layouts, cycled with Alt+[ / Alt+]: grid (default,
// equal-area balanced grid), spiral (balanced), columns (equal side-by-side).
// The FIRST swap_tiled_layout listed is the one zellij selects on startup, so
// grid is defined first to make it the default; the cycle order follows the
// listing (grid → spiral → columns).
// Need to wire up the bars explicitly here because zellij only injects them
// automatically when using the built-in default layout, not a custom one.
// status-bar normally renders two rows (hotkeys + tips); we constrain it to
// size=1 so only the hotkey-hints row shows. The bar updates in place when
// entering chord modes (e.g. Ctrl-t shows tab-mode hints). The bottom bar is
// our fork of zellij:status-bar (see zellij/status-bar/): the bottom-right
// quick hints are condensed to a single flat "Super + <c,p,t,y>" block (the
// four launchers — claude / pane / tab / yazi-peek — keys only, no word-labels
// and no powerline ribbons), where upstream renders a longer labelled strip.
// That block only shows in Locked mode; once unlocked (Normal) the left ribbon
// already lists every submode, so the right side is left empty.
//
// The top bar is our fork of zellij:tab-bar (see zellij/tab-bar/), which
// REPLACED the third-party zjstatus that used to live here. zjstatus had no
// tab scroll viewport, so on a thin pane the tabs ran under the right-hand
// widgets and clipped mid-ribbon. The fork keeps upstream tab-bar's
// active-anchored scroll (active tab always visible, overflow collapsed into
// left/right `+N` count pills), themed to nebelung, and renders itself the
// two bits zjstatus was originally adopted for: the peach username pill on
// the left (passed in as `username`) and the Ctrl+Tab reminder + Alt <[]>
// swap-layout ribbon on the right. Tab/ribbon colours come straight from the
// zellij "nebelung" theme (ribbon_selected/unselected), so there's nothing to
// theme here. This file is NOT installed verbatim: default.nix renders it to
// ~/.config/zellij/layouts/custom.kdl, substituting the @…@ tokens (colour
// hexes and the login name live in the nebelung repo / nix, never here).
layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="file:@HOME@/.config/zellij/plugins/tab-bar.wasm" {
                username "@username@"
            }
        }
        children
        pane size=1 borderless=true {
            plugin location="file:@HOME@/.config/zellij/plugins/status-bar.wasm"
        }
    }

    tab {
        pane
    }

    // Grid (DEFAULT): packs the panes into the most balanced grid for their count,
    // sizing each column proportionally to how many panes it holds so EVERY pane ends
    // up the same area — the largest that count allows. Whole squares/rectangles come
    // out even (4→2×2, 6→3×2, 9→3×3); odd counts get a proportionally narrower
    // column for the leftover so nothing is cramped (3 → one narrow pane on the
    // left + two wider stacked on the right, all equal area). The count is split
    // into ceil(√n) columns, extra panes filling the rightmost columns first.
    // Best when you want every agent on screen and as large as possible at once.
    //
    // ⚠ max_panes counts EVERY pane in the tab, and default_tab_template injects a
    // tab-bar + status-bar pane into each one — so a tab showing N content panes
    // actually holds N+2 panes. Every max_panes below is therefore (content + 2);
    // the trailing comment is the content count each template targets. (Without the
    // +2, zellij matches a too-large template and partial-fills it — e.g. 6 content
    // panes fell into the 8-slot template and rendered [2,3,1] instead of 3×2.)
    swap_tiled_layout name="GRID" {
        tab max_panes=3 {  // 1
            pane
        }
        tab max_panes=4 {  // 2 — side by side
            pane split_direction="vertical" {
                pane
                pane
            }
        }
        // [1,2] — single left (⅓), two stacked right (⅔)  ·  3 content
        tab max_panes=5 {
            pane split_direction="vertical" {
                pane size="34%"
                pane size="66%" {
                    pane
                    pane
                }
            }
        }
        // [2,2] — 2×2  ·  4 content
        tab max_panes=6 {
            pane split_direction="vertical" {
                pane {
                    pane
                    pane
                }
                pane {
                    pane
                    pane
                }
            }
        }
        // [1,2,2] — narrow single + two 2-stacks  ·  5 content
        tab max_panes=7 {
            pane split_direction="vertical" {
                pane size="20%"
                pane size="40%" {
                    pane
                    pane
                }
                pane size="40%" {
                    pane
                    pane
                }
            }
        }
        // [2,2,2] — 3×2  ·  6 content
        tab max_panes=8 {
            pane split_direction="vertical" {
                pane {
                    pane
                    pane
                }
                pane {
                    pane
                    pane
                }
                pane {
                    pane
                    pane
                }
            }
        }
        // [2,2,3] — two 2-stacks + one wider 3-stack  ·  7 content
        tab max_panes=9 {
            pane split_direction="vertical" {
                pane size="29%" {
                    pane
                    pane
                }
                pane size="28%" {
                    pane
                    pane
                }
                pane size="43%" {
                    pane
                    pane
                    pane
                }
            }
        }
        // [2,3,3] — one 2-stack + two wider 3-stacks  ·  8 content
        tab max_panes=10 {
            pane split_direction="vertical" {
                pane size="25%" {
                    pane
                    pane
                }
                pane size="37%" {
                    pane
                    pane
                    pane
                }
                pane size="38%" {
                    pane
                    pane
                    pane
                }
            }
        }
        // [3,3,3] — 3×3  ·  9 content
        tab max_panes=11 {
            pane split_direction="vertical" {
                pane {
                    pane
                    pane
                    pane
                }
                pane {
                    pane
                    pane
                    pane
                }
                pane {
                    pane
                    pane
                    pane
                }
            }
        }
        // 10+ — even 4-column fallback (fills up to 12, overflow reflows)
        tab {
            pane split_direction="vertical" {
                pane {
                    pane
                    pane
                    pane
                }
                pane {
                    pane
                    pane
                    pane
                }
                pane {
                    pane
                    pane
                    pane
                }
                pane {
                    pane
                    pane
                    pane
                }
            }
        }
    }

    // Spiral: every split is an even 50/50 halve, alternating
    // vertical/horizontal, always nesting into the last (bottom-right)
    // pane. Biggest pane stays on the left, then top-right, then
    // bottom-right, and so on inward. Geometry is a pure function of the
    // pane count, so closing any pane reflows to the same canonical form
    // regardless of which side was closed.
    // max_panes is content+2 (tab-bar + status-bar panes count too — see grid).
    swap_tiled_layout name="SPIRAL" {
        tab max_panes=3 {  // 1
            pane
        }
        tab max_panes=4 {  // 2
            pane split_direction="vertical" {
                pane
                pane
            }
        }
        tab max_panes=5 {  // 3
            pane split_direction="vertical" {
                pane
                pane {
                    pane
                    pane
                }
            }
        }
        tab max_panes=6 {  // 4
            pane split_direction="vertical" {
                pane
                pane {
                    pane
                    pane split_direction="vertical" {
                        pane
                        pane
                    }
                }
            }
        }
        tab max_panes=7 {  // 5
            pane split_direction="vertical" {
                pane
                pane {
                    pane
                    pane split_direction="vertical" {
                        pane
                        pane {
                            pane
                            pane
                        }
                    }
                }
            }
        }
        tab {  // 6+
            pane split_direction="vertical" {
                pane
                pane {
                    pane
                    pane split_direction="vertical" {
                        pane
                        pane {
                            pane
                            pane split_direction="vertical" {
                                pane
                                pane
                            }
                        }
                    }
                }
            }
        }
    }

    // Columns: every pane an equal full-height column, side by side. Best for
    // eyeballing 2–4 agents at once on a wide display; gets narrow past ~5.
    // max_panes is content+2 (tab-bar + status-bar panes count too — see grid).
    swap_tiled_layout name="COLUMNS" {
        tab max_panes=3 {  // 1
            pane
        }
        tab max_panes=4 {  // 2
            pane split_direction="vertical" {
                pane
                pane
            }
        }
        tab max_panes=5 {  // 3
            pane split_direction="vertical" {
                pane
                pane
                pane
            }
        }
        tab max_panes=6 {  // 4
            pane split_direction="vertical" {
                pane
                pane
                pane
                pane
            }
        }
        tab max_panes=7 {  // 5
            pane split_direction="vertical" {
                pane
                pane
                pane
                pane
                pane
            }
        }
        tab {  // 6+
            pane split_direction="vertical" {
                pane
                pane
                pane
                pane
                pane
                pane
            }
        }
    }
}
