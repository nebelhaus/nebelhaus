default_layout "custom"
pane_frames false
scroll_buffer_size 50000
serialize_pane_viewport true
// Clean up grid-selections before they hit the clipboard: dedent the message
// gutter and rejoin hard-wrapped prose, while leaving code/lists/tables intact.
// (Script pipes the cleaned text to pbcopy itself.) See copy-clean.pl.
copy_command "@HOME@/.config/zellij/copy-clean.pl"
show_release_notes false
show_startup_tips false
// Nebelung (catppuccin-mocha with the blue muted out) — the theme block lives
// in ~/.config/zellij/themes/nebelung.kdl, dropped there by home-manager from
// the nebelung flake. Keep this name in sync with that block's name.
theme "nebelung"

// Option+Click a path in any pane → new tab cwd'd there, named after the repo
// (hover shows the underline/italic hint). link-handler is our fork of
// zellij's built-in `link` plugin — same path detection, but the click opens
// a new tab cwd'd at the path instead of $EDITOR. Declaring load_plugins here
// REPLACES the default config's list (which auto-loads "zellij:link"), so
// this one line both disables the built-in and loads the fork. The wasm is
// built by nix from zellij/link-handler/ and dropped here by home-manager;
// its permissions are pre-seeded into zellij's cache (see hearth) because a
// background plugin has no pane to show the grant prompt in.
load_plugins {
    "file:~/.config/zellij/plugins/link-handler.wasm"
    // tab-history — Ctrl(+Shift)+Tab walk tabs in most-recently-used order
    // (browser-style back/forward) instead of by position. Loaded here as a
    // background plugin so it records focus history from session start; the
    // Ctrl Tab / Ctrl Shift Tab binds below MessagePlugin "back"/"forward" to
    // it. Its grants are pre-seeded into zellij's permission cache by hearth,
    // same as link-handler. See zellij/tab-history/src/main.rs.
    "file:~/.config/zellij/plugins/tab-history.wasm"
}

keybinds {
    shared {
        // Super c — spawn an ISOLATED claude agent. --worktree hands the
        // session its own checkout (the `wt` WorktreeCreate hook in
        // ~/.claude/settings.json places it under ~/.cache/claude-worktrees/
        // <repo>/<name>, branch worktree-<name>, branched from local HEAD), so
        // parallel agents never move this checkout's branch out from under
        // each other. Merge/inspect their branches from the main checkout;
        // `bench status` lists them. Cmd c reaches zellij as Super c because
        // ghostty/config unbinds cmd+c; the status-bar fork renders the
        // "Super + c claude" hint next to pane/tab in the bottom-right.
        //
        // No --dangerously-skip-permissions here: hearth pins
        // permissions.defaultMode = "auto" in ~/.claude/settings.json (the
        // claudeCodePermissionMode activation), so agents run unattended with
        // background safety checks rather than the old blanket bypass.
        bind "Super c" { Run "claude" "--worktree"; }
        // Ctrl Alt Shift c — the resident agent: works IN this checkout, on
        // whatever branch you're looking at. At most one per tab, by
        // convention — it's the only claude allowed to touch the real tree.
        bind "Ctrl Alt Shift c" { Run "claude"; }
        // Super p — New pane, inheriting the focused pane's cwd — except next
        //            to a claude --worktree pane: hearth's zshrc notices a
        //            fresh shell starting inside ~/.cache/claude-worktrees and
        //            hops it to the repo's main checkout instead (the agent's
        //            throwaway dir is no place for a human shell).
        bind "Super p" { NewPane; }
        // Super Shift p — New pane that STAYS in the focused pane's cwd, hop and
        //            all suppressed: the no-hop sibling of Super p, for when you
        //            DO want a shell inside an agent's worktree checkout. Runs
        //            the login shell with ZJ_STAY=1 set, which hearth's zshrc
        //            reads to skip the ~/.cache/claude-worktrees → main-checkout
        //            hop (see modules/hearth default.nix). Reaches zellij because
        //            ghostty/config unbinds cmd+shift+p (its command palette).
        bind "Super Shift p" { Run "sh" "-c" "ZJ_STAY=1 exec \"$SHELL\""; }

        // Super l — "fix layout": force the focused pane's TUI to re-read its
        //            width, then redraw. A fast ghostty resize (an app tiling
        //            in beside the terminal, then leaving) can leave zellij on
        //            a size it thinks the pane already has, so it never
        //            re-signals the child — claude code keeps wrapping at the
        //            stale narrow width and a bare ctrl+l only redraws at that
        //            wrong width. Toggling fullscreen twice drives the pane
        //            through a real geometry change and back to the identical
        //            layout, which re-sets the child's winsize + fires SIGWINCH;
        //            the trailing Write 12 (^L) then clears the stale wrapping.
        //            Needs ghostty/config's `cmd+l=unbind` to reach zellij.
        bind "Super l" {
            ToggleFocusFullscreen
            ToggleFocusFullscreen
            Write 12
        }

        // yazi as a floating overlay — appears on top of the tiled claude panes,
        // dismissed with q, leaving the tiled layout untouched.
        //
        // Super y  — Peek: file browser rooted at the focused pane's cwd (its
        //            repo). Live markdown/code preview; Enter on a FILE pages it
        //            fullscreen, Enter on a DIRECTORY opens a new zellij tab
        //            cwd'd there (the old Super-Shift-t picker, now folded in —
        //            l/→ still descends to browse). See peek-run.sh + the
        //            peek-open yazi plugin.
        bind "Super y" {
            Run "@HOME@/.config/zellij/peek.sh" {
                floating true
                close_on_exit true
                x "100%"; y "100%"; width "1%"; height "1%"
            }
        }
        // Super Shift y — Jump: browse, quit, and the float becomes a shell in
        //            the directory you landed on. Scratch terminal on demand.
        bind "Super Shift y" {
            Run "@HOME@/.config/zellij/yazi-shell.sh" {
                floating true
                name "shell"
                x "5%"; y "5%"; width "90%"; height "90%"
            }
        }
        // Super t — New tab at $HOME, wherever the focused pane lives: the
        //            plain "give me a fresh tab" bind. Tab-level cwd is the only
        //            form zellij honors under a custom default_tab_template, so
        //            this opens home.kdl (custom.kdl with the content tab pinned
        //            cwd=$HOME, rendered next to it by hearth). It's this NewTab
        //            action the status-bar fork surfaces as the `t` in the
        //            "Super + <c,p,t,y>" hint block.
        bind "Super t" { NewTab { layout "@HOME@/.config/zellij/layouts/home.kdl"; }; }
        // Super Shift t — New tab cwd'd at the FOCUSED pane's directory (the
        //            "open a tab right here" sibling of Super t's "…at home").
        //            Runs new-tab-here.sh as a throwaway 1%-corner floating pane,
        //            which inherits the focused pane's cwd as $PWD, then clones
        //            the active layout with a tab-level cwd injected (a bare
        //            `new-tab --cwd` is ignored under the custom
        //            default_tab_template — the same layout trick peek-run.sh and
        //            the link-handler use). Reaches zellij because ghostty/config
        //            unbinds cmd+shift+t.
        bind "Super Shift t" {
            Run "@HOME@/.config/zellij/new-tab-here.sh" {
                floating true
                close_on_exit true
                name "new-tab"
                x "100%"; y "100%"; width "1%"; height "1%"
            }
        }
        // Ctrl (Shift) Tab — walk tabs in most-recently-used order via the
        // tab-history plugin (see load_plugins above), NOT by position:
        // Ctrl Tab goes "back" toward older/previously-focused tabs, Ctrl
        // Shift Tab goes "forward" back toward where you came from — like a
        // browser's history. Repeated presses within ~1.5s walk a frozen
        // snapshot back and forth; after ~1.5s of stillness the tab you
        // landed on commits as the new "current" node. Works in any mode.
        // Only works at all because ghostty/config explicitly sends the
        // kitty-protocol encoding for these (macOS AppKit otherwise swallows
        // ctrl+tab before the terminal sees it). The custom layout's tab-bar
        // shows the "Ctrl+Tab" reminder top-right.
        bind "Ctrl Tab" {
            MessagePlugin "file:~/.config/zellij/plugins/tab-history.wasm" {
                name "back"
            }
        }
        bind "Ctrl Shift Tab" {
            MessagePlugin "file:~/.config/zellij/plugins/tab-history.wasm" {
                name "forward"
            }
        }
    }
}
