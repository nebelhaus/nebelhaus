theme = dark:nebelung,light:Catppuccin Latte

font-family = JetBrainsMono Nerd Font Mono
font-size = 19

# Auto-attach to (or create) the "main" zellij session on launch.
# Skipped for quick-terminal, for nested ghostty (already inside zellij),
# and when NO_ZELLIJ=1 is set. Falls back to plain zsh if zellij errors.
command = @HOME@/.config/zellij/launch.sh

macos-titlebar-style = hidden
macos-option-as-alt = true

# Make zellij's bottom status bar sit flush along the window's bottom edge at
# EVERY font size. The ghostty window is tiled at a fixed pixel height (prowl /
# AeroSpace), so when a font size doesn't divide the height evenly, ghostty
# leaves the leftover pixels as padding on the BOTTOM (and right) edge —
# window-padding-balance defaults to false. That's why the top tab-bar always
# looks flush but the bottom status-bar floats above a background-coloured gap,
# and why only a few zoom levels (font-size 19 out of the box) happen to divide
# evenly. Painting that leftover padding with the nearest grid cell's background
# (the zellij status-bar row) makes the bar bleed its own colour down to the
# window edge, so it reads as flush at any zoom level.
#
# This MUST be `extend-always`, not plain `extend`. `extend` applies heuristics
# that disable extension row-by-row, and the zellij bar row trips two of them:
# it contains powerline separator glyphs () and its right end has default-
# background cells — both of which ghostty's `extend` refuses to paint (it
# assumes powerline ribbons and default-bg gaps look wrong extended). An earlier
# attempt with plain `extend` shipped on the theory that these heuristics only
# apply to primary-screen apps and zellij (alt-screen) is exempt; that was
# wrong — the gap persisted in a fresh ghostty. `extend-always` forces the
# extension unconditionally, ignoring every heuristic, which is exactly what a
# uniform full-width status bar wants.
window-padding-color = extend-always

# extend-always alone still dumps 100% of the non-divisible leftover on the
# BOTTOM edge (balance defaults to false), so at zoom levels where the remainder
# is large the extended status-bar background reads as a fat slab of dead space
# below the last row — "flush" but bottom-heavy. Balancing splits the remainder
# evenly top/bottom (and left/right): the visible bottom band halves, and its
# other half moves to the TOP, where extend-always paints it with the tab-bar
# row's background (the dark terminal bg) so it blends into the surrounding black
# and stays invisible. Worst-case band is thus ~half a cell height, not a full
# one, at every zoom.
window-padding-balance = true

quit-after-last-window-closed = true
window-save-state = never
confirm-close-surface = false

#zellij overwrites
keybind = cmd+t=unbind
keybind = cmd+p=unbind
# cmd+shift+p → zellij "Super Shift p": a new pane that STAYS in the focused
# pane's cwd, even inside an agent worktree (the no-hop sibling of cmd+p).
# Ghostty binds cmd+shift+p to its command palette by default — unbind it so the
# chord reaches zellij instead of popping the palette.
keybind = cmd+shift+p=unbind
keybind = cmd+y=unbind
keybind = cmd+shift+y=unbind
keybind = cmd+shift+t=unbind
# cmd+l → zellij "Super l" (force a genuine PTY winsize kick + ^L redraw). A
# fast WM resize of the ghostty window — an app tiling in beside it, then
# leaving — can land zellij back on a size it already thinks the pane has, so
# it never re-signals the child; the pane's TUI (claude code) keeps wrapping at
# the stale narrow width, and a bare ctrl+l only redraws at that wrong width.
keybind = cmd+l=unbind
# cmd+f → zellij "Super f" (toggle the focused pane fullscreen). Ghostty binds
# cmd+f to its native-macOS window fullscreen by default — unbind it so the
# chord reaches zellij and zooms the pane instead of the whole window.
keybind = cmd+f=unbind
# cmd+c → zellij "Super c" (spawn a claude --worktree agent). Unbinding drops
# ghostty's copy-on-cmd+c, but our copy path is zellij selection → copy_command
# (copy-clean.pl), not ghostty's raw-grid copy, so normal copying is unaffected.
keybind = cmd+c=unbind
# ghostty binds ctrl+tab to its own next_tab/previous_tab by default, and
# even unbound, macOS AppKit swallows ctrl+tab for focus navigation before
# the terminal core sees it. So bind it to SEND the kitty-keyboard-protocol
# encoding explicitly (CSI 9;5u / 9;6u = ctrl+Tab / ctrl+shift+Tab); zellij's
# config.kdl binds those to the tab-history plugin (MRU back/forward).
keybind = ctrl+tab=text:\x1b[9;5u
keybind = ctrl+shift+tab=text:\x1b[9;6u

macos-icon-frame = chrome
macos-icon-ghost-color = 333333
macos-icon-screen-color = 404040

macos-icon = custom-style
